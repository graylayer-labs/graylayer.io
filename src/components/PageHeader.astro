---
interface Props {
  tag: string;
  title: string;
  description?: string;
}

const { tag, title, description } = Astro.props;
---

<header class="page-header">
  <span class="page-tag">{tag}</span>
  <h1 class="page-title">{title}</h1>
  {description && <p class="page-desc">{description}</p>}
</header>

<style>
  .page-header {
    padding: 56px var(--space-page) 40px;
    max-width: 640px;
  }

  .page-tag {
    display: block;
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    margin-bottom: 16px;
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(26px, 3.5vw, 40px);
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: 14px;
  }

  .page-desc {
    font-size: 13px;
    color: var(--color-text-muted);
    font-weight: 300;
    line-height: 1.8;
  }
</style>
