---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <span class="footer-copy">© {year} Eoin McAllister</span>
  <div class="footer-links">
    <a href="https://github.com/graylayer-labs" target="_blank" rel="noopener">GitHub</a>
    <a href="https://linkedin.com/in/eoin-mcallister-ml" target="_blank" rel="noopener">LinkedIn</a>
    <a href="mailto:eoinmc.james@gmail.com">Email</a>
    <a href="/rss.xml">RSS</a>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 0.5px solid var(--color-border);
    padding: 18px var(--space-page);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-copy {
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--color-text-faint);
  }

  .footer-links {
    display: flex;
    gap: 20px;
  }

  .footer-links a {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .footer-links a:hover {
    color: var(--color-text);
  }
</style>
