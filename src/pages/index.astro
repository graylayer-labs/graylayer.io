---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Home"
  description="ML Engineer. Hybrid RL agents and production ML systems."
>
  <div class="hero">
    <p class="hero-label">eoin mcallister</p>
    <h1 class="hero-h1">
      Work at the boundary<br />
      <em>of known and unknown.</em>
    </h1>
    <p class="hero-lead">
      ML Engineer. I build hybrid RL agents and production ML systems.<br />
      Current work: language-conditioned control without retraining.
    </p>
    <div class="hero-actions">
      <a href="/research" class="btn-primary">Research</a>
      <a href="/projects" class="btn-ghost">Open source</a>
    </div>
  </div>

  <section class="cards-section">
    <div class="card">
      <span class="card-tag">01 — Research</span>
      <h3 class="card-title">Lang Control RL</h3>
      <p class="card-body">Hybrid SAC agent conditioned on natural language goals via a learned encoder. Objective-flexible competence without retraining.</p>
      <a href="/research" class="card-link">Read more →</a>
    </div>
    <div class="card">
      <span class="card-tag">02 — Projects</span>
      <h3 class="card-title">graylayer-labs</h3>
      <p class="card-body">Open-source tooling for RL experimentation, reusable MLOps primitives, and ML infrastructure. Fetched live from GitHub.</p>
      <a href="/projects" class="card-link">View repos →</a>
    </div>
    <div class="card">
      <span class="card-tag">03 — Writing</span>
      <h3 class="card-title">Notes</h3>
      <p class="card-body">Occasional writing on RL theory, production ML systems, and whatever I'm working through.</p>
      <a href="/blog" class="card-link">Read →</a>
    </div>
  </section>

  <div class="status-bar">
    <div class="status-item">
      <span class="status-dot"></span>
      <span>Active — Lang Control RL</span>
    </div>
    <div class="status-links">
      <a href="https://github.com/graylayer-labs" target="_blank" rel="noopener">GitHub</a>
      <a href="https://linkedin.com/in/eoin-mcallister-ml" target="_blank" rel="noopener">LinkedIn</a>
    </div>
  </div>
</BaseLayout>

<style>
  .hero {
    padding: var(--space-section) var(--space-page) 56px;
    max-width: 680px;
  }

  .hero-label {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    margin-bottom: 22px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .hero-label::before {
    content: '';
    display: block;
    width: 20px;
    height: 0.5px;
    background: var(--color-text-faint);
  }

  .hero-h1 {
    font-family: var(--font-serif);
    font-size: clamp(30px, 4vw, 48px);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin-bottom: 22px;
  }

  .hero-h1 em {
    font-style: italic;
    color: var(--color-text-muted);
  }

  .hero-lead {
    font-size: 13px;
    line-height: 1.8;
    color: var(--color-text-muted);
    font-weight: 300;
    max-width: 440px;
    margin-bottom: 36px;
  }

  .hero-lead strong {
    font-weight: 400;
    color: var(--color-text);
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-primary {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 9px 18px;
    background: var(--color-text);
    color: var(--color-bg);
    display: inline-block;
  }

  .btn-ghost {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 9px 18px;
    background: transparent;
    color: var(--color-text-muted);
    border: 0.5px solid var(--color-border-mid);
    display: inline-block;
  }

  .btn-ghost:hover {
    color: var(--color-text);
  }

  .cards-section {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 0.5px solid var(--color-border);
    margin-top: 56px;
  }

  .card {
    padding: 28px var(--space-page);
    border-right: 0.5px solid var(--color-border);
  }

  .card:last-child {
    border-right: none;
  }

  .card-tag {
    display: block;
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    margin-bottom: 14px;
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: 10px;
  }

  .card-body {
    font-size: 12px;
    line-height: 1.75;
    color: var(--color-text-muted);
    font-weight: 300;
  }

  .card-link {
    display: inline-block;
    margin-top: 18px;
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--color-text-faint);
  }

  .card-link:hover {
    color: var(--color-text);
  }

  @media (max-width: 720px) {
    .cards-section {
      grid-template-columns: 1fr;
    }

    .card {
      border-right: none;
      border-bottom: 0.5px solid var(--color-border);
    }

    .card:last-child {
      border-bottom: none;
    }
  }

  .status-bar {
    border-top: 0.5px solid var(--color-border);
    padding: 14px var(--space-page);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .status-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--color-text-faint);
  }

  .status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #3B6D11;
    flex-shrink: 0;
  }

  .status-links {
    display: flex;
    gap: 18px;
  }

  .status-links a {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .status-links a:hover {
    color: var(--color-text);
  }
</style>
