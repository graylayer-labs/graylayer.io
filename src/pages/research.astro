---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
---

<BaseLayout
  title="Research"
  description="Research directions and current work in reinforcement learning, hybrid control, and language-conditioned behaviour."
>
  <PageHeader
    tag="Research"
    title="Research focus."
    description="The main thread is reinforcement learning systems that are easier to control, evaluate, and reuse."
  />

  <section class="research-grid">
    <article class="research-main">
      <div class="research-block">
        <span class="block-label">Current thread</span>
        <h2>Language-conditioned control without retraining.</h2>
        <p>
          I’m exploring RL agents that can adapt behaviour from natural-language goals without
          learning a fresh policy for every task variant. The motivating question is how to build
          agents that are more flexible at inference time while staying grounded in stable training
          pipelines.
        </p>
        <p>
          The work combines hybrid control ideas, learned language representations, and a practical
          concern for what can actually be trained, inspected, and iterated on by a small team.
        </p>
      </div>

      <div class="research-block">
        <span class="block-label">Questions I care about</span>
        <ul>
          <li>RL architectures that separate reusable competence from task-specific objectives</li>
          <li>Evaluation setups that make behavioural changes obvious and measurable</li>
          <li>Tooling that shortens the loop between experiment design and implementation</li>
          <li>Interfaces between language signals and continuous-control policies</li>
        </ul>
      </div>
    </article>

    <aside class="research-side">
      <div class="side-block">
        <span class="block-label">How I work</span>
        <p>I prefer research that ends in code, measurable outputs, and a system another engineer can understand.</p>
      </div>

      <div class="side-block">
        <span class="block-label">Relevant outputs</span>
        <ul>
          <li><a href="/projects">Open-source repositories</a></li>
          <li><a href="/blog">Research notes and writing</a></li>
          <li><a href="https://github.com/graylayer-labs" target="_blank" rel="noopener">graylayer-labs on GitHub</a></li>
        </ul>
      </div>

      <div class="side-block">
        <span class="block-label">Next additions</span>
        <p>Benchmark notes, project write-ups, and experiment details for current RL work.</p>
      </div>
    </aside>
  </section>
</BaseLayout>

<style>
  .research-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.7fr) minmax(280px, 1fr);
    border-top: 0.5px solid var(--color-border);
  }

  .research-main,
  .research-side {
    padding: 32px var(--space-page) 56px;
  }

  .research-main {
    border-right: 0.5px solid var(--color-border);
  }

  .research-block + .research-block,
  .side-block + .side-block {
    margin-top: 28px;
    padding-top: 28px;
    border-top: 0.5px solid var(--color-border);
  }

  .block-label {
    display: block;
    margin-bottom: 14px;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .research-main h2 {
    font-family: var(--font-serif);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 400;
    line-height: 1.1;
    margin-bottom: 18px;
    max-width: 640px;
  }

  .research-main p,
  .research-side p,
  .research-main li,
  .research-side li {
    font-size: 13px;
    line-height: 1.9;
    color: var(--color-text-muted);
    font-weight: 300;
  }

  .research-main ul,
  .research-side ul {
    padding-left: 18px;
  }

  .research-main li + li,
  .research-side li + li {
    margin-top: 10px;
  }

  .research-side a {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-border-mid);
  }

  @media (max-width: 860px) {
    .research-grid {
      grid-template-columns: 1fr;
    }

    .research-main {
      border-right: none;
      border-bottom: 0.5px solid var(--color-border);
    }
  }
</style>
