---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

interface Repo {
  id: number;
  name: string;
  full_name: string;
  description: string | null;
  html_url: string;
  stargazers_count: number;
  language: string | null;
  topics: string[];
  updated_at: string;
  fork: boolean;
  archived: boolean;
  visibility: string;
}

let repos: Repo[] = [];
let fetchError = false;

try {
  const res = await fetch(
    'https://api.github.com/orgs/graylayer-labs/repos?sort=updated&per_page=100&type=public',
    {
      headers: {
        Accept: 'application/vnd.github+json',
        'X-GitHub-Api-Version': '2022-11-28',
        ...(import.meta.env.GITHUB_TOKEN
          ? { Authorization: `Bearer ${import.meta.env.GITHUB_TOKEN}` }
          : {}),
      },
    }
  );

  if (res.ok) {
    const data: Repo[] = await res.json();
    repos = data
      .filter((r) => !r.fork && !r.archived)
      .sort((a, b) => b.stargazers_count - a.stargazers_count || new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime());
  } else {
    fetchError = true;
  }
} catch {
  fetchError = true;
}

const fmtDate = (d: string) =>
  new Date(d).toLocaleDateString('en-GB', { month: 'short', year: 'numeric' });
---

<BaseLayout
  title="Projects"
  description="Tooling and experiments from graylayer-labs."
>
  <PageHeader
    tag="Projects"
    title="Open source."
    description="Tooling and experiments from graylayer-labs."
  />

  <hr style="border: none; border-top: 0.5px solid var(--color-border); margin: 0 var(--space-page);" />

  <section class="content-area">
    <div class="intro">
      <p>
        These are the public repositories that best reflect how I build: practical ML tooling,
        RL infrastructure, and systems work that is meant to be inspected and extended.
      </p>
    </div>

    {fetchError && (
      <p class="fallback">
        Repos temporarily unavailable. View directly on{' '}
        <a href="https://github.com/graylayer-labs" target="_blank" rel="noopener">GitHub</a>.
      </p>
    )}

    {repos.length === 0 && !fetchError && (
      <p class="fallback">No public repositories found.</p>
    )}

    {repos.length > 0 && (
      <div class="repo-list">
        {repos.map((repo) => (
          <a href={repo.html_url} class="repo-item" target="_blank" rel="noopener noreferrer">
            <div class="repo-top">
              <span class="repo-name">{repo.name}</span>
              {repo.language && <span class="repo-lang">{repo.language}</span>}
            </div>
            {repo.description && <p class="repo-desc">{repo.description}</p>}
            <div class="repo-meta">
              {repo.stargazers_count > 0 && <span>{repo.stargazers_count} stars</span>}
              <span>Updated {fmtDate(repo.updated_at)}</span>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

</BaseLayout>

<style>
  .content-area {
    min-height: 200px;
    padding-bottom: 56px;
  }

  .intro {
    padding: 28px var(--space-page);
    border-bottom: 0.5px solid var(--color-border);
    max-width: 860px;
  }

  .intro p {
    font-size: 13px;
    color: var(--color-text-muted);
    font-weight: 300;
    line-height: 1.85;
  }

  .fallback {
    padding: 40px var(--space-page);
    font-size: 13px;
    color: var(--color-text-muted);
    font-weight: 300;
  }

  .fallback a {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .repo-list {
    border-top: 0.5px solid var(--color-border);
  }

  .repo-item {
    display: block;
    padding: 20px var(--space-page);
    border-bottom: 0.5px solid var(--color-border);
    transition: background 0.1s;
  }

  .repo-item:hover {
    background: rgba(128, 128, 120, 0.04);
  }

  .repo-top {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 6px;
  }

  .repo-name {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text);
  }

  .repo-lang {
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    border: 0.5px solid var(--color-border-mid);
    padding: 2px 7px;
  }

  .repo-desc {
    font-size: 12px;
    color: var(--color-text-muted);
    font-weight: 300;
    line-height: 1.65;
    margin-bottom: 8px;
  }

  .repo-meta {
    display: flex;
    gap: 16px;
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--color-text-faint);
  }
</style>
