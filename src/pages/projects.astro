---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';

interface Repo {
  id: number;
  name: string;
  full_name: string;
  description: string | null;
  html_url: string;
  stargazers_count: number;
  language: string | null;
  topics: string[];
  updated_at: string;
  fork: boolean;
  archived: boolean;
  visibility: string;
}

let repos: Repo[] = [];
let fetchError = false;

try {
  const res = await fetch(
    'https://api.github.com/orgs/graylayer-labs/repos?sort=updated&per_page=100&type=public',
    {
      headers: {
        Accept: 'application/vnd.github+json',
        'X-GitHub-Api-Version': '2022-11-28',
        ...(import.meta.env.GITHUB_TOKEN
          ? { Authorization: `Bearer ${import.meta.env.GITHUB_TOKEN}` }
          : {}),
      },
    }
  );

  if (res.ok) {
    const data: Repo[] = await res.json();
    repos = data
      .filter((r) => !r.fork && !r.archived)
      .sort((a, b) => b.stargazers_count - a.stargazers_count || new Date(b.updated_at).getTime() - new Date(a.updated_at).getTime());
  } else {
    fetchError = true;
  }
} catch {
  fetchError = true;
}

const fmtDate = (d: string) =>
  new Date(d).toLocaleDateString('en-GB', { month: 'short', year: 'numeric' });
---

<BaseLayout
  title="Projects"
  description="Tooling and experiments from graylayer-labs."
>
  <PageHeader
    tag="Projects"
    title="Projects and code."
    description="Case studies, working notes, and public repositories."
  />

  <hr style="border: none; border-top: 0.5px solid var(--color-border); margin: 0 var(--space-page);" />

  <section class="content-area">
    <div class="intro">
      <p>
        This page mixes two things: project write-ups and public repositories. The write-ups are
        the better place to understand design decisions. The repo list is there if you want to go
        straight to code.
      </p>
    </div>

    <section class="section-block">
      <div class="section-header">
        <span class="section-label">Case studies</span>
        <h2>Project pages</h2>
      </div>

      <div class="feature-list">
        <a href="/projects/control-console" class="feature-item">
          <div>
            <span class="feature-tag">Dummy project</span>
            <h3>Control Console for RL Experiments</h3>
            <p>
              Placeholder project used to shape the portfolio. The page layout is meant to show
              how a real engineering case study should read.
            </p>
          </div>
          <span class="feature-link">Open project</span>
        </a>
      </div>
    </section>

    {fetchError && (
      <p class="fallback">
        Repos temporarily unavailable. View directly on{' '}
        <a href="https://github.com/graylayer-labs" target="_blank" rel="noopener">GitHub</a>.
      </p>
    )}

    {repos.length === 0 && !fetchError && (
      <p class="fallback">No public repositories found.</p>
    )}

    {repos.length > 0 && (
      <section class="section-block">
        <div class="section-header">
          <span class="section-label">Repositories</span>
          <h2>Public GitHub repos</h2>
        </div>

        <div class="repo-list">
          {repos.map((repo) => (
            <a href={repo.html_url} class="repo-item" target="_blank" rel="noopener noreferrer">
              <div class="repo-top">
                <span class="repo-name">{repo.name}</span>
                {repo.language && <span class="repo-lang">{repo.language}</span>}
              </div>
              {repo.description && <p class="repo-desc">{repo.description}</p>}
              <div class="repo-meta">
                {repo.stargazers_count > 0 && <span>{repo.stargazers_count} stars</span>}
                <span>Updated {fmtDate(repo.updated_at)}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </section>

</BaseLayout>

<style>
  .content-area {
    min-height: 200px;
    padding-bottom: 56px;
  }

  .intro {
    padding: 28px var(--space-page);
    border-bottom: 0.5px solid var(--color-border);
    max-width: 860px;
  }

  .intro p {
    font-size: 13px;
    color: var(--color-text-muted);
    font-weight: 300;
    line-height: 1.85;
  }

  .section-block {
    padding-top: 28px;
  }

  .section-header {
    padding: 0 var(--space-page) 18px;
  }

  .section-label,
  .feature-tag {
    display: block;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .section-header h2 {
    margin-top: 10px;
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 400;
    line-height: 1.15;
  }

  .feature-list {
    border-top: 0.5px solid var(--color-border);
    border-bottom: 0.5px solid var(--color-border);
  }

  .feature-item {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
    padding: 24px var(--space-page);
    transition: background 0.1s;
  }

  .feature-item:hover {
    background: rgba(128, 128, 120, 0.04);
  }

  .feature-item h3 {
    margin-top: 10px;
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 400;
    line-height: 1.2;
  }

  .feature-item p {
    margin-top: 10px;
    max-width: 720px;
    font-size: 12px;
    color: var(--color-text-muted);
    font-weight: 300;
    line-height: 1.75;
  }

  .feature-link {
    flex-shrink: 0;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .fallback {
    padding: 40px var(--space-page);
    font-size: 13px;
    color: var(--color-text-muted);
    font-weight: 300;
  }

  .fallback a {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .repo-list {
    border-top: 0.5px solid var(--color-border);
  }

  .repo-item {
    display: block;
    padding: 20px var(--space-page);
    border-bottom: 0.5px solid var(--color-border);
    transition: background 0.1s;
  }

  .repo-item:hover {
    background: rgba(128, 128, 120, 0.04);
  }

  .repo-top {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 6px;
  }

  .repo-name {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text);
  }

  .repo-lang {
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    border: 0.5px solid var(--color-border-mid);
    padding: 2px 7px;
  }

  .repo-desc {
    font-size: 12px;
    color: var(--color-text-muted);
    font-weight: 300;
    line-height: 1.65;
    margin-bottom: 8px;
  }

  .repo-meta {
    display: flex;
    gap: 16px;
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--color-text-faint);
  }

  @media (max-width: 720px) {
    .feature-item {
      flex-direction: column;
    }
  }
</style>
