---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout
  title="Blog"
  description="No cadence. Written when there's something worth saying."
>
  <PageHeader
    tag="Writing"
    title="Notes."
    description="No cadence. Written when there's something worth saying."
  />

  <hr style="border: none; border-top: 0.5px solid var(--color-border); margin: 0 var(--space-page);" />

  <section class="content-area">
    {posts.length === 0 ? (
      <p class="empty">Nothing here yet.</p>
    ) : (
      <div class="post-list">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="post-item">
            <span class="post-title">{post.data.title}</span>
            <time class="post-date">{fmt(post.data.pubDate)}</time>
          </a>
        ))}
      </div>
    )}
  </section>

  <div class="status-bar">
    <div class="status-item">
      <span class="status-dot"></span>
      <span>Active — Lang Control RL</span>
    </div>
    <div class="status-links">
      <a href="https://github.com/graylayer-labs" target="_blank" rel="noopener">GitHub</a>
      <a href="https://linkedin.com/in/eoin-mcallister-ml" target="_blank" rel="noopener">LinkedIn</a>
    </div>
  </div>
</BaseLayout>

<style>
  .content-area {
    min-height: 200px;
  }

  .empty {
    padding: 40px var(--space-page);
    font-size: 13px;
    color: var(--color-text-muted);
    font-weight: 300;
  }

  .post-list {
    border-top: 0.5px solid var(--color-border);
  }

  .post-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    padding: 16px var(--space-page);
    border-bottom: 0.5px solid var(--color-border);
    transition: background 0.1s;
  }

  .post-item:hover {
    background: rgba(128, 128, 120, 0.04);
  }

  .post-title {
    font-size: 13px;
    color: var(--color-text);
    font-weight: 400;
  }

  .post-date {
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--color-text-faint);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .status-bar {
    border-top: 0.5px solid var(--color-border);
    padding: 14px var(--space-page);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .status-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--color-text-faint);
  }

  .status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #3B6D11;
    flex-shrink: 0;
  }

  .status-links {
    display: flex;
    gap: 18px;
  }

  .status-links a {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .status-links a:hover {
    color: var(--color-text);
  }
</style>
