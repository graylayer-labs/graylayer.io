---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout
  title="Blog"
  description="No cadence. Written when there's something worth saying."
>
  <PageHeader
    tag="Writing"
    title="Notes."
    description="No cadence. Written when there's something worth saying."
  />

  <hr style="border: none; border-top: 0.5px solid var(--color-border); margin: 0 var(--space-page);" />

  <section class="content-area">
    {posts.length === 0 ? (
      <div class="empty">
        <p>No posts published yet.</p>
        <p>Writing here will focus on RL systems, experiments, and notes from production ML work.</p>
      </div>
    ) : (
      <div class="post-list">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="post-item">
            <span class="post-title">{post.data.title}</span>
            <time class="post-date">{fmt(post.data.pubDate)}</time>
          </a>
        ))}
      </div>
    )}
  </section>

</BaseLayout>

<style>
  .content-area {
    min-height: 200px;
    padding-bottom: 56px;
  }

  .empty {
    padding: 40px var(--space-page);
    border-top: 0.5px solid var(--color-border);
  }

  .empty p {
    font-size: 13px;
    color: var(--color-text-muted);
    font-weight: 300;
    line-height: 1.85;
  }

  .empty p + p {
    margin-top: 10px;
  }

  .post-list {
    border-top: 0.5px solid var(--color-border);
  }

  .post-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    padding: 16px var(--space-page);
    border-bottom: 0.5px solid var(--color-border);
    transition: background 0.1s;
  }

  .post-item:hover {
    background: rgba(128, 128, 120, 0.04);
  }

  .post-title {
    font-size: 13px;
    color: var(--color-text);
    font-weight: 400;
  }

  .post-date {
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--color-text-faint);
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>
