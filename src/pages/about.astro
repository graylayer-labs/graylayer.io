---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
---

<BaseLayout
  title="About"
  description="About Eoin McAllister, an ML engineer working across reinforcement learning, experimentation, and production systems."
>
  <PageHeader
    tag="About"
    title="I work where research and engineering meet."
    description="I’m an ML engineer based in Dublin, focused on reinforcement learning systems, experimental infrastructure, and production-facing ML software."
  />

  <section class="about-grid">
    <div class="about-main">
      <p>
        My work sits in the gap between promising ideas and reliable systems. I’m interested in
        reinforcement learning, controllable agent behaviour, evaluation, and the engineering work
        required to make ML useful beyond a demo.
      </p>
      <p>
        I’ve worked in environments where the job is not just to train a model, but to build the
        surrounding machinery: data flows, interfaces, experiments, tooling, and the habits that
        make iteration faster and safer.
      </p>
      <p>
        This site is a compact record of that work. Recruiters should be able to see my scope
        quickly. Engineers should be able to inspect the projects and understand how I think.
      </p>
    </div>

    <div class="about-side">
      <div class="detail-block">
        <span class="detail-label">Experience</span>
        <ul>
          <li>Currently building at UrbanFox</li>
          <li>Previously at Intel</li>
          <li>Based in Dublin, Ireland</li>
        </ul>
      </div>

      <div class="detail-block">
        <span class="detail-label">Focus areas</span>
        <ul>
          <li>Reinforcement learning</li>
          <li>Language-conditioned control</li>
          <li>ML tooling and infrastructure</li>
          <li>Production ML systems</li>
        </ul>
      </div>

      <div class="detail-block">
        <span class="detail-label">Links</span>
        <ul>
          <li><a href="/projects">Projects</a></li>
          <li><a href="/research">Research</a></li>
          <li><a href="https://github.com/graylayer-labs" target="_blank" rel="noopener">GitHub</a></li>
          <li><a href="https://linkedin.com/in/eoin-mcallister-ml" target="_blank" rel="noopener">LinkedIn</a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.7fr) minmax(280px, 1fr);
    gap: 0;
    border-top: 0.5px solid var(--color-border);
  }

  .about-main,
  .about-side {
    padding: 32px var(--space-page) 56px;
  }

  .about-main {
    border-right: 0.5px solid var(--color-border);
    max-width: 760px;
  }

  .about-main p {
    font-size: 13px;
    line-height: 1.95;
    color: var(--color-text-muted);
    font-weight: 300;
    margin-bottom: 20px;
  }

  .detail-block + .detail-block {
    margin-top: 28px;
    padding-top: 28px;
    border-top: 0.5px solid var(--color-border);
  }

  .detail-label {
    display: block;
    margin-bottom: 14px;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .detail-block ul {
    list-style: none;
  }

  .detail-block li {
    font-size: 12px;
    line-height: 1.8;
    color: var(--color-text-muted);
    font-weight: 300;
    margin-bottom: 8px;
  }

  .detail-block a {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-border-mid);
  }

  @media (max-width: 860px) {
    .about-grid {
      grid-template-columns: 1fr;
    }

    .about-main {
      border-right: none;
      border-bottom: 0.5px solid var(--color-border);
    }
  }
</style>
