---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/PageHeader.astro';
---

<BaseLayout
  title="About"
  description="ML Engineer based in Dublin. Previously Intel. Building at UrbanFox."
>
  <PageHeader
    tag="About"
    title="Eoin McAllister."
    description="ML Engineer based in Dublin. Previously Intel. Building at UrbanFox."
  />

  <hr style="border: none; border-top: 0.5px solid var(--color-border); margin: 0 var(--space-page);" />

  <section class="content-area"></section>

  <div class="status-bar">
    <div class="status-item">
      <span class="status-dot"></span>
      <span>Active — Lang Control RL</span>
    </div>
    <div class="status-links">
      <a href="https://github.com/graylayer-labs" target="_blank" rel="noopener">GitHub</a>
      <a href="https://linkedin.com/in/eoin-mcallister-ml" target="_blank" rel="noopener">LinkedIn</a>
    </div>
  </div>
</BaseLayout>

<style>
  .content-area {
    min-height: 200px;
  }

  .status-bar {
    border-top: 0.5px solid var(--color-border);
    padding: 14px var(--space-page);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .status-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--color-text-faint);
  }

  .status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #3B6D11;
    flex-shrink: 0;
  }

  .status-links {
    display: flex;
    gap: 18px;
  }

  .status-links a {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .status-links a:hover {
    color: var(--color-text);
  }
</style>
